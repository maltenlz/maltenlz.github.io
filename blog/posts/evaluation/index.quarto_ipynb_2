      "source": [
        "#| label: fig-contamination\n",
        "#| fig-cap: Train, test, and production data — the overlap we can no longer measure.\n",
        "\n",
        "import matplotlib.pyplot as plt\n",
        "from matplotlib.patches import Circle\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(6, 5))\n",
        "\n",
        "r = 0.28\n",
        "centers = {\n",
        "    \"X_pretrain\":   (0.35, 0.62),\n",
        "    \"X_test\":       (0.65, 0.62),\n",
        "    \"X_production\": (0.50, 0.36),\n",
        "}\n",
        "colors = {\n",
        "    \"X_pretrain\":   (\"#b91c1c\", \"#7f1d1d\"),\n",
        "    \"X_test\":       (\"#4338ca\", \"#1e1b4b\"),\n",
        "    \"X_production\": (\"#15803d\", \"#14532d\"),\n",
        "}\n",
        "\n",
        "for name, (cx, cy) in centers.items():\n",
        "    fc, ec = colors[name]\n",
        "    ax.add_patch(Circle((cx, cy), r, fc=fc, ec=ec, alpha=0.35))\n",
        "\n",
        "# Labels at each circle's center, shifted away from the overlap region\n",
        "ax.text(0.27, 0.66, \"X_pretrain\",   ha=\"center\", va=\"center\", fontsize=11, color=\"#7f1d1d\", weight=\"bold\")\n",
        "ax.text(0.73, 0.66, \"X_test\",       ha=\"center\", va=\"center\", fontsize=11, color=\"#1e1b4b\", weight=\"bold\")\n",
        "ax.text(0.50, 0.30, \"X_production\", ha=\"center\", va=\"center\", fontsize=11, color=\"#14532d\", weight=\"bold\")\n",
        "\n",
        "# Question mark at the X_pretrain ∩ X_test intersection only\n",
        "ax.text(0.50, 0.66, \"?\", ha=\"center\", va=\"center\", fontsize=28, color=\"#1f2937\", weight=\"bold\")\n",
        "\n",
        "ax.set_xlim(0, 1); ax.set_ylim(0, 1)\n",
        "ax.set_aspect(\"equal\"); ax.axis(\"off\")\n",
        "fig.subplots_adjust(left=0.05, right=0.95, top=0.92, bottom=0.08)\n",
        "plt.show()"
      ],
