    "#| label: fig-forecast\n",
    "#| fig-cap: Synthetic demand series with a simple rolling-mean forecast.\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "rng = np.random.default_rng(42)\n",
    "t = pd.date_range(\"2025-01-01\", periods=120, freq=\"D\")\n",
    "trend = np.linspace(100, 140, len(t))\n",
    "seasonal = 8 * np.sin(2 * np.pi * np.arange(len(t)) / 7)\n",
    "noise = rng.normal(0, 4, len(t))\n",
    "y = trend + seasonal + noise\n",
    "\n",
    "series = pd.Series(y, index=t, name=\"demand\")\n",
    "forecast = series.rolling(window=14, min_periods=1).mean()\n",
    "\n",
    "fig, ax = plt.subplots()\n",
    "ax.plot(series.index, series.values, label=\"actual\", lw=1, alpha=0.6)\n",
    "ax.plot(forecast.index, forecast.values, label=\"14-day rolling mean\", lw=2)\n",
    "ax.set_xlabel(\"date\")\n",
    "ax.set_ylabel(\"demand\")\n",
    "ax.legend(frameon=False)\n",
    "fig.tight_layout()\n",
    "plt.show()"
   ]
